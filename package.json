{
  "name": "google-map-mcp",
  "version": "1.0.0",
  "description": "Google Maps Places API MCP server for intelligent place discovery and business lead generation",
  "main": "dist/index.js",
  "bin": {
    "google-map-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup && chmod +x dist/index.js",
    "build:typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
