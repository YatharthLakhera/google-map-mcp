# Copy to .env on the VPS and fill in values before running docker compose up
# cp env.docker.example .env

GOOGLE_PLACES_API_KEY=your_api_key_here

# Shared secret Hermes must send as: Authorization: Bearer <token>
# Generate one with: openssl rand -hex 32
MCP_AUTH_TOKEN=your_secret_token_here

# Name of the Docker network Hermes is on.
# Find it with: docker network ls
HERMES_NETWORK=hermes-net

# Set to "true" if the Hermes network was created by another compose file
# (i.e. it already exists before you run this compose)
HERMES_NETWORK_EXTERNAL=true

# Optional overrides
RATE_LIMIT_PER_DAY=1000
CACHE_TTL_SECONDS=604800
