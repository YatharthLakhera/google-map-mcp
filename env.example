# Google Places API (New) key — enable "Places API (New)" in Google Cloud Console
GOOGLE_PLACES_API_KEY=your_api_key_here

# Optional: max Google API calls per 24-hour window (default: 1000)
# RATE_LIMIT_PER_DAY=1000

# Optional: override default cache DB location (~/.google-map-mcp/cache.db)
# CACHE_DB_PATH=/path/to/custom/cache.db

# Optional: cache TTL in seconds (default: 604800 = 7 days)
# CACHE_TTL_SECONDS=604800
